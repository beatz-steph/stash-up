{
  "name": "stashup",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "postinstall": "pnpm --filter @workspace/db run db:generate",
    "build": "pnpm --filter @workspace/db run db:generate && turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.9.18",
    "typescript": "^5",
    "vitest": "^4.1.9",
    "vitest-mock-extended": "^4.0.0"
  },
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=20"
  }
}
